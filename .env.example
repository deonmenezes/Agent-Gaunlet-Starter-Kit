# Agent Gauntlet server IP or hostname. The starter kit derives:
# - REST API:  http://ARENA_SERVER:8000
# - MCP URL:   http://ARENA_SERVER:5001
# - LLM proxy: http://ARENA_SERVER:4001
ARENA_SERVER=<organizer-provided-host>

# Shared Agent Gauntlet key provided by the organizer. This key is used for
# REST and MCP access, and as the default for LLM proxy access.
# No separate NVIDIA, OpenAI, OpenRouter, or other external provider key is needed.
ARENA_API_KEY=

# Team identity and strategy settings now live in:
#   my_strategy.py
